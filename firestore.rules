rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for static schema verification
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isValidId(configId);
    }

    match /content/{contentId} {
      allow read: if true;
      allow write: if isValidId(contentId);
    }

    match /members/{memberId} {
      allow read: if true;
      allow write: if isValidId(memberId);
    }

    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if isValidId(transactionId);
    }

    match /visitors/{visitorLogId} {
      allow read: if true;
      allow write: if isValidId(visitorLogId);
    }
  }
}
